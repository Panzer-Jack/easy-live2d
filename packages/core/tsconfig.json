{
  "compilerOptions": {
    "target": "esnext",
    "rootDir": "..",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@Framework/*": ["../cubism/Framework/src/*"]
    },
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist"
  },
  "splitting": true,
  "sourcemap": true,
  "include": [
    "src/**/*.ts",
    "../cubism/Framework/src/**/*.ts",
    "../cubism/Core/*.ts"
  ]
}
